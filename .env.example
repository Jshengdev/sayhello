# .env.example — the Airbyte recall ADD-ON env delta (worktree feat/airbyte-recall).
# The CORE sayhello demo needs none of these. This file documents ONLY the keys the recall add-on
# uses. Copy the values you have into the repo-root .env (gitignored). NEVER commit real values.

# ── Notion: the durable memory surface (Story -> Notion writer + Notion-direct recall fallback) ──
# Create an internal integration at https://www.notion.com/my-integrations, copy its token, then
# SHARE the target page/database with that integration (•••  -> Connections -> your integration).
NOTION_API_KEY=               # required to write/query Notion. FAILS LOUD if unset.
NOTION_DATABASE_ID=           # preferred: the "sayhello stories" database to write into / query.
NOTION_PARENT_PAGE_ID=        # alt: if no DATABASE_ID, the seed script CREATES the DB under this page.

# ── Airbyte Agent Engine: the PRIMARY recall path (context_store_search over the Context Store) ──
# Free signup at https://app.airbyte.ai (no card). Add the Notion connector, sync the "sayhello
# stories" DB into the Context Store, then authenticate the MCP at https://mcp.airbyte.ai/mcp.
# If unset, recall falls back to Notion-direct, then the always-on local grounded corpus.
AIRBYTE_MCP_TOKEN=            # bearer/OAuth token for https://mcp.airbyte.ai/mcp (or set AIRBYTE_API_KEY).
AIRBYTE_API_KEY=             # alt name accepted for the MCP bearer token.
# AIRBYTE_MCP_URL=https://mcp.airbyte.ai/mcp   # override only if your endpoint differs.
# AIRBYTE_SEARCH_TOOL=context_store_search     # override if your account exposes a different tool name.

# ── ports (worktree parallelism) ──
# The recall worktree runs a second backend so it doesn't clash with the main demo's :8787.
# PORT=8799                                   # backend port (default 8787).
# NEXT_PUBLIC_API_URL=http://localhost:8799   # point the recall frontend at this backend.
